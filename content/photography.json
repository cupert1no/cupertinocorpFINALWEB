{
  "projects": [
    {
      "key": "business",
      "label": "Business Opportunities",
      "description": "Una exploración visual del espacio entre el trabajo y la identidad. Imágenes tomadas en entornos corporativos y laborales que cuestionan qué significa producir, mostrar y pertenecer.",
      "order": 1
    },
    {
      "key": "vectoralist",
      "label": "The Vectoralist",
      "description": "Serie inspirada en el concepto de McKenzie Wark: el vectoralista como nueva clase dominante que controla el flujo de información. Las imágenes buscan representar la abstracción del poder contemporáneo.",
      "order": 2
    },
    {
      "key": "device",
      "label": "Device",
      "description": "Objetos, pantallas, superficies. Una mirada cercana a los dispositivos que median nuestra experiencia cotidiana — no como herramientas sino como extensiones del cuerpo y la mente.",
      "order": 3
    },
    {
      "key": "elsewhere",
      "label": "Elsewhere",
      "description": "Imágenes tomadas fuera. Lugares que no son el tuyo pero en los que algo reconoces. Londres, París, cualquier ciudad que te devuelve una mirada.",
      "order": 4
    },
    {
      "key": "print",
      "label": "Print",
      "description": "Trabajo gráfico e impreso. Carteles, piezas visuales y objetos de diseño capturados como fotografía — donde la imagen habla sobre otra imagen.",
      "order": 5
    }
  ],
